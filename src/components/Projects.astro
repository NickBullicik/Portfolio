---
import { projects } from '../data/projects';
import ProjectCard from './ProjectCard.astro';
---

<section id="projects" class="py-24 px-6 border-t border-[#1F1F23]">
  <div class="max-w-5xl mx-auto">
    <div class="flex items-baseline gap-3 mb-3 fade-in">
      <span class="font-mono text-sm text-[#4F8BFF]">0x02</span>
      <h2 class="text-2xl font-semibold text-[#F2F2F0]">
        <span data-lang="es">Proyectos</span>
        <span data-lang="en">Projects</span>
      </h2>
    </div>
    <p class="text-[#7A7A80] mb-14 max-w-xl fade-in text-sm">
      <span data-lang="es">Cuatro aplicaciones terminadas. Cada una cubre un &aacute;rea del ciclo de DAM.</span>
      <span data-lang="en">Four finished applications. Each one covers a different area of the degree.</span>
    </p>

    <div class="grid md:grid-cols-2 gap-x-8 gap-y-12">
      {projects.map((project, index) => (
        <ProjectCard
          number={String(index + 1).padStart(2, '0')}
          title={project.title}
          descriptionEs={project.description.es}
          descriptionEn={project.description.en}
          image={project.image}
          tags={project.tags}
          demoUrl={project.demoUrl}
          githubUrl={project.githubUrl}
        />
      ))}
    </div>
  </div>
</section>
